{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SiteAssure",
  "version": "0.1.0",
  "identifier": "org.pursuit.siteassure",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'"
    },
    "windows": [{ "title": "SiteAssure", "width": 420, "height": 880 }]
  }
}
