{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resona",
  "version": "0.1.0",
  "identifier": "dev.resona.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Resona",
        "width": 920,
        "height": 760,
        "minWidth": 560,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
